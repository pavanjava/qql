    'severity': 'high',
    'year': 2024,
    'peer_reviewed': true
  },
  {
    'text': 'Diffuse large B-cell lymphoma is treated with R-CHOP achieving cure in 60% of patients. CAR-T therapy with axicabtagene ciloleucel or lisocabtagene maraleucel is approved for relapsed or refractory DLBCL after two prior lines.',
    'title': 'DLBCL CAR-T Therapy in Relapsed Disease',
    'department': 'oncology',
    'sub_specialty': 'hematologic_oncology',
    'document_type': 'clinical_guideline',
