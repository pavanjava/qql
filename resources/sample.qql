INSERT BULK INTO COLLECTION medical_records VALUES [
  {
    'text': 'EGFR-mutant NSCLC with exon 19 deletion or L858R responds to TKIs. Third-generation osimertinib is preferred first-line due to superior CNS penetration and activity against T790M resistance mutations over erlotinib and gefitinib.',
