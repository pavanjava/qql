INSERT BULK INTO COLLECTION medical_records VALUES [
  {
    'text': 'Ventricular tachycardia in structural heart disease carries sudden cardiac death risk. ICD is first-line in LVEF below 35%. Catheter ablation reduces VT burden. Amiodarone is the most efficacious antiarrhythmic agent available.',
