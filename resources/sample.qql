    'peer_reviewed': true
  },
  {
    'text': 'Pulmonary arterial hypertension with mean PAP above 20mmHg is treated with endothelin receptor antagonists, PDE5 inhibitors, and prostacyclin analogues. Upfront combination therapy improves long-term survival in high-risk patients.',
    'title': 'Pulmonary Arterial Hypertension Combination Therapy',
    'department': 'cardiology',
    'sub_specialty': 'pulmonary_hypertension',
    'document_type': 'clinical_guideline',
    'icd10_code': 'I27.0',
